# Auto detect text files and perform LF normalization
* text=auto

# Explicitly declare files that should always be LF
*.py text eol=lf
*.sh text eol=lf
*.md text eol=lf
*.toml text eol=lf
*.json text eol=lf

# Global ignore for Git
.DS_Store -text
*.png binary
*.jpg binary
*.wav binary
*.mp3 binary
