@page
@model IndexModel
@{
    ViewData["Title"] = "Home";
}

@if (Model.IsAuthenticated && Model.Stats != null)
{
    <!-- ═══ Authenticated Dashboard ═══ -->
    <div class="animate-in">
        <div class="card-header" style="margin-bottom: 32px;">
            <div>
                <h1 class="card-title" style="font-size: 2rem;">🚀 Welcome back, @(User.Claims.FirstOrDefault(c => c.Type == "FullName")?.Value ?? User.Identity?.Name)</h1>
                <p style="color: var(--text-secondary); margin-top: 4px;">Here's what's happening with your transcriptions.</p>
            </div>
            <a asp-page="/Jobs/Create" class="btn btn-primary btn-lg">➕ New Transcription</a>
        </div>

        <!-- Quick Stats -->
        <div class="stats-grid">
            <div class="stat-card">
                <div class="stat-value">@Model.Stats.TotalJobs</div>
                <div class="stat-label">Total Jobs</div>
            </div>
            <div class="stat-card">
                <div class="stat-value">@Model.Stats.TotalMinutesTranscribed</div>
                <div class="stat-label">Minutes Transcribed</div>
            </div>
            <div class="stat-card">
                <div class="stat-value">@Model.Stats.MinutesUsedThisMonth</div>
                <div class="stat-label">Used This Month</div>
            </div>
            <div class="stat-card">
                <div class="stat-value" style="background: var(--text-primary); -webkit-text-fill-color: var(--text-primary);">@Model.Stats.Plan</div>
                <div class="stat-label">Current Plan</div>
            </div>
        </div>

        <div style="display: grid; grid-template-columns: 1fr 340px; gap: 24px; align-items: start;">
            <!-- Recent Activity -->
            <div class="card">
                <div class="card-header" style="margin-bottom: 20px;">
                    <h2 class="card-title" style="font-size: 1.1rem;">🕒 Recent Activity</h2>
                    <a asp-page="/Jobs/Index" class="nav-link" style="padding: 0;">View All</a>
                </div>

                @if (!Model.RecentJobs.Any())
                {
                    <p style="color: var(--text-muted); text-align: center; padding: 40px 0;">No recent activity. Try transcribing a file!</p>
                }
                else
                {
                    <div class="table-container">
                        <table class="data-table">
                            <thead>
                                <tr>
                                    <th>File</th>
                                    <th>Status</th>
                                    <th>Date</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var job in Model.RecentJobs)
                                {
                                    <tr>
                                        <td>
                                            <div style="font-weight: 500; font-size: 0.9rem;">@job.OriginalFilename</div>
                                        </td>
                                        <td>
                                            <span class="badge badge-@job.Status.ToLower()">@job.Status</span>
                                        </td>
                                        <td style="font-size: 0.85rem; color: var(--text-secondary);">
                                            @job.CreatedAt.ToLocalTime().ToString("MMM dd")
                                        </td>
                                        <td style="text-align: right;">
                                            <a asp-page="/Jobs/Details" asp-route-id="@job.Id" class="btn btn-secondary btn-sm">View</a>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>

            <!-- Quick Tips / Getting Started -->
            <div style="display: flex; flex-direction: column; gap: 24px;">
                <div class="card card-glass" style="border-color: var(--accent-primary);">
                    <h3 style="font-size: 1rem; margin-bottom: 12px;">💡 Quick Tip</h3>
                    <p style="font-size: 0.85rem; color: var(--text-secondary); line-height: 1.5;">
                        Using <strong>Meeting Mode</strong> will automatically extract action items and next steps from your transcript.
                    </p>
                </div>

                <div class="card">
                    <h3 style="font-size: 1rem; margin-bottom: 12px;">🛠 Tools</h3>
                    <ul style="list-style: none; display: flex; flex-direction: column; gap: 12px;">
                        <li><a href="#" class="nav-link" style="padding: 0; display: flex; align-items: center; gap: 10px;"><span>🔌</span> Chrome Extension</a></li>
                        <li><a href="#" class="nav-link" style="padding: 0; display: flex; align-items: center; gap: 10px;"><span>📱</span> Mobile Web App</a></li>
                        <li><a href="#" class="nav-link" style="padding: 0; display: flex; align-items: center; gap: 10px;"><span>🔧</span> API Settings</a></li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
}
else
{
    <!-- ═══ Guest Hero Section ═══ -->
    <div class="hero animate-in">
        <div class="badge badge-completed" style="margin-bottom: 24px; background: rgba(99, 102, 241, 0.1);">
            ✨ Powered by Llama 3.3 & Whisper Turbo
        </div>
        <h1 class="hero-title">Turn Speech into <br/>Actionable Intelligence</h1>
        <p class="hero-subtitle">
            TranscribeAI uses state-of-the-art AI to transcribe, summarize, and extract next steps from your meetings and lectures in seconds.
        </p>
        <div class="hero-actions">
            <a asp-page="/Account/Register" class="btn btn-primary btn-lg">Get Started for Free</a>
            <a href="#features" class="btn btn-secondary btn-lg">Learn More</a>
        </div>

        <div style="margin-top: 60px; position: relative;">
            <div class="card card-glass animate-in" style="max-width: 900px; margin: 0 auto; height: 400px; border-bottom: 0; border-radius: var(--radius-xl) var(--radius-xl) 0 0; overflow: hidden; background: linear-gradient(to bottom, rgba(26, 31, 46, 0.8), rgba(10, 14, 26, 1));">
                <div style="padding: 20px; border-bottom: 1px solid var(--border-color); display: flex; gap: 8px;">
                    <div style="width: 12px; height: 12px; border-radius: 50%; background: #ff5f56;"></div>
                    <div style="width: 12px; height: 12px; border-radius: 50%; background: #ffbd2e;"></div>
                    <div style="width: 12px; height: 12px; border-radius: 50%; background: #27c93f;"></div>
                </div>
                <div style="padding: 40px; text-align: left;">
                    <div style="width: 60%; height: 24px; background: rgba(255,255,255,0.05); border-radius: 4px; margin-bottom: 20px;"></div>
                    <div style="width: 80%; height: 16px; background: rgba(255,255,255,0.03); border-radius: 4px; margin-bottom: 12px;"></div>
                    <div style="width: 75%; height: 16px; background: rgba(255,255,255,0.03); border-radius: 4px; margin-bottom: 12px;"></div>
                    <div style="width: 40%; height: 16px; background: rgba(255,255,255,0.03); border-radius: 4px; margin-bottom: 40px;"></div>
                    
                    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px;">
                        <div class="card" style="padding: 20px; border-color: var(--accent-primary);">
                            <div style="width: 30%; height: 12px; background: var(--accent-glow); border-radius: 4px; margin-bottom: 12px;"></div>
                            <div style="width: 90%; height: 8px; background: rgba(255,255,255,0.02); border-radius: 4px; margin-bottom: 8px;"></div>
                            <div style="width: 85%; height: 8px; background: rgba(255,255,255,0.02); border-radius: 4px;"></div>
                        </div>
                        <div class="card" style="padding: 20px;">
                            <div style="width: 30%; height: 12px; background: rgba(255,255,255,0.05); border-radius: 4px; margin-bottom: 12px;"></div>
                            <div style="width: 90%; height: 8px; background: rgba(255,255,255,0.02); border-radius: 4px; margin-bottom: 8px;"></div>
                            <div style="width: 85%; height: 8px; background: rgba(255,255,255,0.02); border-radius: 4px;"></div>
                        </div>
                    </div>
                </div>
            </div>
            <div style="position: absolute; bottom: 0; left: 0; right: 0; height: 100px; background: linear-gradient(to top, var(--bg-primary), transparent);"></div>
        </div>
    </div>

    <!-- Features Section -->
    <div id="features" style="padding: 80px 0;">
        <div style="text-align: center; margin-bottom: 60px;">
            <h2 style="font-size: 2.5rem; font-weight: 700; margin-bottom: 16px;">Everything you need for speech</h2>
            <p style="color: var(--text-secondary); max-width: 600px; margin: 0 auto;">Streamline your workflow with tools designed for efficiency and clarity.</p>
        </div>

        <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 32px;">
            <div class="card">
                <div style="font-size: 2.5rem; margin-bottom: 20px;">⚡</div>
                <h3 style="margin-bottom: 12px;">Ultra-Fast Transcription</h3>
                <p style="font-size: 0.9rem; color: var(--text-secondary);">Powered by Whisper Turbo, transcribing audio in 1/10th of its actual duration with near-perfect accuracy.</p>
            </div>
            <div class="card">
                <div style="font-size: 2.5rem; margin-bottom: 20px;">🧠</div>
                <h3 style="margin-bottom: 12px;">AI Meeting Intelligence</h3>
                <p style="font-size: 0.9rem; color: var(--text-secondary);">Automatically summarize meetings, extract action items, and detect speakers with Llama 3.3.</p>
            </div>
            <div class="card">
                <div style="font-size: 2.5rem; margin-bottom: 20px;">💬</div>
                <h3 style="margin-bottom: 12px;">Interactive Transcript Chat</h3>
                <p style="font-size: 0.9rem; color: var(--text-secondary);">Ask questions directly to your transcript. Our AI knows exactly what was said and when.</p>
            </div>
        </div>
    </div>
}
