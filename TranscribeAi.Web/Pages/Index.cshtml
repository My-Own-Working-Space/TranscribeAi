@page
@model IndexModel
@{
    ViewData["Title"] = "Home";
}

@if (Model.IsAuthenticated && Model.Stats != null)
{
    <!-- Dashbaord remains same -->
    <div class="animate-in" style="padding: 40px 24px; max-width: 1200px; margin: 0 auto;">
        <div style="margin-bottom: 40px; display: flex; justify-content: space-between; align-items: flex-end;">
            <div>
                <h1 style="font-size: 2.25rem; font-weight: 800; color: var(--text-primary);">Welcome back, @(User.Claims.FirstOrDefault(c => c.Type == "FullName")?.Value ?? User.Identity?.Name)</h1>
                <p style="color: var(--text-secondary); margin-top: 8px;">You have transcribed @Model.Stats.TotalMinutesTranscribed minutes this month.</p>
            </div>
            <a asp-page="/Jobs/Create" class="btn btn-primary" style="padding: 12px 24px;">New Transcription</a>
        </div>

        <div class="features-grid" style="margin-bottom: 48px; grid-template-columns: repeat(3, 1fr);">
            <div class="feature-card" style="padding: 24px;">
                <div style="color: var(--text-muted); font-size: 0.75rem; text-transform: uppercase; font-weight: 700; margin-bottom: 8px;">Total Projects</div>
                <div style="font-size: 2rem; font-weight: 800;">@Model.Stats.TotalJobs</div>
            </div>
            <div class="feature-card" style="padding: 24px;">
                <div style="color: var(--text-muted); font-size: 0.75rem; text-transform: uppercase; font-weight: 700; margin-bottom: 8px;">Minutes Used</div>
                <div style="font-size: 2rem; font-weight: 800;">@Model.Stats.TotalMinutesTranscribed</div>
            </div>
            <div class="feature-card" style="padding: 24px;">
                <div style="color: var(--text-muted); font-size: 0.75rem; text-transform: uppercase; font-weight: 700; margin-bottom: 8px;">Active Plan</div>
                <div style="font-size: 2rem; font-weight: 800;">@Model.Stats.Plan</div>
            </div>
        </div>

        <div style="display: grid; grid-template-columns: 1fr 300px; gap: 40px;">
            <div class="feature-card" style="padding: 0; overflow: hidden; align-items: stretch; text-align: left;">
                <div style="padding: 20px 24px; border-bottom: 1px solid var(--border-color); display: flex; justify-content: space-between; align-items: center;">
                    <h3 style="font-size: 1.1rem; font-weight: 700;">Recent Projects</h3>
                    <a asp-page="/Jobs/Index" style="font-size: 0.85rem; color: var(--accent-primary); text-decoration: none; font-weight: 600;">View All</a>
                </div>
                
                @if (!Model.RecentJobs.Any())
                {
                    <div style="padding: 40px; text-align: center; color: var(--text-muted);">No projects found.</div>
                }
                else
                {
                    <table style="width: 100%; border-collapse: collapse;">
                        @foreach (var job in Model.RecentJobs)
                        {
                            <tr style="border-bottom: 1px solid #f9fafb;">
                                <td style="padding: 16px 24px; font-weight: 600; font-size: 0.95rem;">@job.OriginalFilename</td>
                                <td style="padding: 16px 24px; text-align: right;">
                                    <a asp-page="/Jobs/Details" asp-route-id="@job.Id" style="color: var(--accent-primary); font-weight: 600; text-decoration: none; font-size: 0.85rem;">Open</a>
                                </td>
                            </tr>
                        }
                    </table>
                }
            </div>

            <div>
                <div class="feature-card" style="background: var(--nav-bg); color: white; border: none; text-align: center;">
                    <h3 style="font-size: 1rem; margin-bottom: 8px;">Upload Media</h3>
                    <p style="font-size: 0.85rem; opacity: 0.8; margin-bottom: 20px;">Ready to start another transcription?</p>
                    <a asp-page="/Jobs/Create" class="btn" style="background: white; color: var(--nav-bg); width: 100%;">Upload File</a>
                </div>
            </div>
        </div>
    </div>
}
else
{
    <div class="hero animate-in">
        <h1 class="hero-title">High-Accuracy AI <br/>Transcription & Intelligence</h1>
        <p class="hero-subtitle">Convert your meetings, lectures, and videos into perfect text with powerful AI summaries and insights.</p>
        <div style="display: flex; gap: 16px; justify-content: center;">
            <a asp-page="/Account/Register" class="btn btn-primary" style="padding: 14px 32px; font-size: 1rem; border-radius: 4px;">Get Started for Free</a>
            <a href="#features" class="btn" style="border: 1px solid var(--border-color); padding: 14px 32px;">Learn More</a>
        </div>

        <div style="margin-top: 80px; max-width: 1000px; margin-left: auto; margin-right: auto;">
             <div style="border: 1px solid var(--border-color); border-radius: var(--radius-md); background: #ffffff; box-shadow: 0 20px 50px rgba(0,0,0,0.08); overflow: hidden;">
                <div style="padding: 12px 20px; border-bottom: 1px solid var(--border-color); display: flex; gap: 6px; background: #f9fafb;">
                    <div style="width: 10px; height: 10px; border-radius: 50%; background: #e5e7eb;"></div>
                    <div style="width: 10px; height: 10px; border-radius: 50%; background: #e5e7eb;"></div>
                    <div style="width: 10px; height: 10px; border-radius: 50%; background: #e5e7eb;"></div>
                </div>
                <div style="width: 100%; height: auto; background: #ffffff; display: flex; align-items: center; justify-content: center;">
                    <img src="/images/showcase.png" alt="Showcase" style="width: 100%; height: auto; display: block;" />
                </div>
            </div>
        </div>
    </div>

    <!-- ═══ Features Section (Perfectly Centered) ═══ -->
    <section id="features" class="features-section" style="text-align: center;">
        <div class="container" style="display: flex; flex-direction: column; align-items: center;">
            <div class="section-header" style="text-align: center; margin-left: auto; margin-right: auto;">
                <h2 class="section-title">Everything you need for speech</h2>
                <p class="section-subtitle">Streamline your workflow with tools designed for efficiency, clarity, and deep AI understanding.</p>
            </div>

            <div class="features-grid">
                <!-- Feature 1 -->
                <div class="feature-card">
                    <div class="feature-icon-wrapper">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"></path></svg>
                    </div>
                    <h3>Ultra-Fast Transcription</h3>
                    <p>Powered by Whisper Turbo, transcribing audio in 1/10th of its actual duration with near-perfect accuracy.</p>
                </div>

                <!-- Feature 2 -->
                <div class="feature-card">
                    <div class="feature-icon-wrapper">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"></path></svg>
                    </div>
                    <h3>AI Meeting Intelligence</h3>
                    <p>Automatically summarize meetings, extract action items, and detect speakers using state-of-the-art LLMs.</p>
                </div>

                <!-- Feature 3 -->
                <div class="feature-card">
                    <div class="feature-icon-wrapper">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path><polyline points="7 10 12 15 17 10"></polyline><line x1="12" y1="15" x2="12" y2="3"></line></svg>
                    </div>
                    <h3>Interactive Transcript Chat</h3>
                    <p>Ask questions directly to your transcript. Our AI knows exactly what was said and when.</p>
                </div>
            </div>
        </div>
    </section>
}
