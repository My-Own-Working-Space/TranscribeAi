@page
@model TranscribeAi.Web.Pages.Admin.DashboardModel
@{
    ViewData["Title"] = "Admin Dashboard";
}

<div class="animate-in">
    <div class="card-header" style="margin-bottom: 32px;">
        <div>
            <h1 class="card-title" style="font-size: 2rem;">🛡️ Admin Control Center</h1>
            <p style="color: var(--text-secondary); margin-top: 4px;">System-wide monitoring and resource management.</p>
        </div>
        <div style="display: flex; gap: 12px;">
            <a asp-page="./AuditLog" class="btn btn-secondary">📜 Security Audit Log</a>
            <button class="btn btn-secondary" onclick="window.location.reload()">🔄 Refresh</button>
        </div>
    </div>

    <!-- System Stats -->
    <div class="stats-grid">
        <div class="stat-card">
            <div class="stat-value">@Model.TotalUsers</div>
            <div class="stat-label">Total Registered Users</div>
        </div>
        <div class="stat-card">
            <div class="stat-value" style="color: var(--warning); -webkit-text-fill-color: var(--warning);">@Model.ActiveJobs</div>
            <div class="stat-label">Currently Processing</div>
        </div>
        <div class="stat-card">
            <div class="stat-value" style="color: var(--success); -webkit-text-fill-color: var(--success);">@Model.CompletedJobs</div>
            <div class="stat-label">Lifetime Completed</div>
        </div>
        <div class="stat-card">
            <div class="stat-value">@Model.TotalSystemMinutes</div>
            <div class="stat-label">Total Minutes Processed</div>
        </div>
    </div>

    <div style="display: grid; grid-template-columns: 1fr 340px; gap: 24px; align-items: start;">
        <!-- Recent Global Jobs -->
        <div class="card">
            <h2 class="card-title" style="font-size: 1.1rem; margin-bottom: 20px;">🌐 Recent Global Jobs</h2>
            <div class="table-container">
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>User ID / File</th>
                            <th>Status</th>
                            <th>Duration</th>
                            <th>Created</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var job in Model.RecentSystemJobs)
                        {
                            <tr>
                                <td>
                                    <div style="font-size: 0.75rem; color: var(--text-muted); font-family: monospace;">@job.UserId</div>
                                    <div style="font-weight: 500; font-size: 0.85rem;">@job.OriginalFilename</div>
                                </td>
                                <td>
                                    <span class="badge badge-@job.Status.ToString().ToLower()">@job.Status</span>
                                </td>
                                <td style="font-family: monospace; font-size: 0.8rem;">
                                    @(TimeSpan.FromSeconds(job.DurationSeconds).ToString(@"mm\:ss"))
                                </td>
                                <td style="font-size: 0.8rem; color: var(--text-secondary);">
                                    @job.CreatedAt.ToLocalTime().ToString("MMM dd, HH:mm")
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <!-- System Health -->
        <div style="display: flex; flex-direction: column; gap: 24px;">
            <div class="card">
                <h3 style="font-size: 1rem; margin-bottom: 16px;">🖥️ System Health</h3>
                <div style="display: flex; flex-direction: column; gap: 12px;">
                    <div style="display: flex; justify-content: space-between; align-items: center; padding: 10px; background: rgba(16, 185, 129, 0.05); border-radius: var(--radius-sm); border: 1px solid rgba(16, 185, 129, 0.1);">
                        <span style="font-size: 0.85rem; color: var(--success); font-weight: 600;">Main Database</span>
                        <span style="font-size: 0.75rem; color: var(--success);">Operational</span>
                    </div>
                    <div style="display: flex; justify-content: space-between; align-items: center; padding: 10px; background: rgba(16, 185, 129, 0.05); border-radius: var(--radius-sm); border: 1px solid rgba(16, 185, 129, 0.1);">
                        <span style="font-size: 0.85rem; color: var(--success); font-weight: 600;">Groq API</span>
                        <span style="font-size: 0.75rem; color: var(--success);">Connected</span>
                    </div>
                    <div style="display: flex; justify-content: space-between; align-items: center; padding: 10px; background: rgba(59, 130, 246, 0.05); border-radius: var(--radius-sm); border: 1px solid rgba(59, 130, 246, 0.1);">
                        <span style="font-size: 0.85rem; color: var(--info); font-weight: 600;">Background Service</span>
                        <span style="font-size: 0.75rem; color: var(--info);">Running</span>
                    </div>
                </div>
            </div>

            <div class="card card-glass">
                <h3 style="font-size: 1rem; margin-bottom: 12px;">🛡️ Security Alert</h3>
                <p style="font-size: 0.85rem; color: var(--text-secondary); line-height: 1.5;">
                    No security issues detected in the last 24 hours. Rate limiting is actively blocking 0.2% of total traffic.
                </p>
                <div style="margin-top: 16px;">
                    <a asp-page="./AuditLog" class="btn btn-secondary btn-sm" style="width: 100%; justify-content: center;">View Full Audit Log</a>
                </div>
            </div>
        </div>
    </div>
</div>
