@page
@model TranscribeAi.Web.Pages.Jobs.CreateModel
@{
    ViewData["Title"] = "New Project";
}

<div style="background: #f9fafb; min-height: 100vh; padding: 80px 20px;">
    <div class="card animate-in" style="max-width: 600px; margin: 0 auto; padding: 48px; border-radius: 4px; box-shadow: 0 4px 20px rgba(0,0,0,0.03);">
        <div style="margin-bottom: 40px; text-align: center;">
            <h1 style="font-size: 1.75rem; font-weight: 800; color: var(--app-text); margin-bottom: 12px;">Create a new project</h1>
            <p style="color: #666; font-size: 0.95rem;">Upload your media to generate high-accuracy transcripts.</p>
        </div>

        <form method="post" enctype="multipart/form-data" id="uploadForm">
            <div class="form-group" style="margin-bottom: 32px;">
                <label class="form-label" style="display: block; margin-bottom: 12px; font-weight: 700; font-size: 0.85rem; text-transform: uppercase; color: #555;">Media Source</label>
                
                <div class="upload-zone" id="dropZone" style="border: 2px dashed #ddd; border-radius: 8px; padding: 60px 20px; text-align: center; cursor: pointer; background: #fff; transition: all 0.2s ease; position: relative;">
                    <div style="margin-bottom: 20px;">
                        <svg style="width: 40px; height: 40px; stroke: var(--app-accent); opacity: 0.6;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path><polyline points="17 8 12 3 7 8"></polyline><line x1="12" y1="3" x2="12" y2="15"></line></svg>
                    </div>
                    <h3 style="font-size: 1rem; font-weight: 600; margin-bottom: 4px;">Choose a file or drag it here</h3>
                    <p style="color: #999; font-size: 0.8rem;">MP3, WAV, M4A, MP4, MKV (Max 200MB)</p>
                    <input type="file" asp-for="UploadedFile" id="UploadedFile" style="opacity: 0; position: absolute; inset: 0; width: 100%; height: 100%; cursor: pointer;" accept="audio/*,video/*" />
                </div>
                
                <div id="fileInfo" style="display: none; margin-top: 16px; padding: 12px; background: #ecfdf5; border-radius: 4px; align-items: center; justify-content: space-between;">
                    <div style="font-size: 0.85rem; font-weight: 600; color: #065f46;" id="fileName"></div>
                    <button type="button" class="btn" style="padding: 4px 10px; font-size: 0.75rem; background: #fff; border: 1px solid #ddd;" id="removeFile">Change</button>
                </div>
                <span asp-validation-for="UploadedFile" style="color: #ef4444; font-size: 0.8rem; display: block; margin-top: 8px;"></span>
            </div>

            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 32px;">
                <div class="form-group">
                    <label asp-for="Mode" style="display: block; margin-bottom: 8px; font-weight: 700; font-size: 0.8rem; text-transform: uppercase;">Job Mode</label>
                    <select asp-for="Mode" class="form-select" style="border-radius: 4px;">
                        <option value="Standard">Standard</option>
                        <option value="Meeting">Meeting</option>
                        <option value="Lecture">Lecture</option>
                    </select>
                </div>

                <div class="form-group">
                    <label asp-for="Language" style="display: block; margin-bottom: 8px; font-weight: 700; font-size: 0.8rem; text-transform: uppercase;">Language</label>
                    <input asp-for="Language" class="form-input" placeholder="e.g. en, vi, fr" style="border-radius: 4px;" />
                </div>
            </div>

            <button type="submit" class="btn" style="width: 100%; background: var(--nav-bg); color: #fff; padding: 16px; font-size: 1rem; border-radius: 4px;" id="submitBtn">
                Create Project
            </button>

            <div id="uploadProgress" style="display: none; margin-top: 24px;">
                <div style="display: flex; justify-content: space-between; margin-bottom: 8px; font-size: 0.8rem;">
                    <span style="color: #666;">Uploading...</span>
                    <span id="uploadPercent" style="font-weight: 700; color: var(--app-accent);">0%</span>
                </div>
                <div style="height: 4px; background: #eee; border-radius: 2px; overflow: hidden;">
                    <div id="uploadBar" style="height: 100%; width: 0%; background: var(--app-accent); transition: width 0.3s ease;"></div>
                </div>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script src="~/js/file-upload.js"></script>
}
