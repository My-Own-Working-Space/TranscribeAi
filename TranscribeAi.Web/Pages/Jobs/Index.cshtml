@page
@model TranscribeAi.Web.Pages.Jobs.IndexModel
@{
    ViewData["Title"] = "My Jobs";
}

<div style="background: #f9fafb; min-height: 100vh; padding: 60px 24px;">
    <div style="max-width: 1200px; margin: 0 auto;">
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 40px;">
            <h1 style="font-size: 2rem; font-weight: 800; color: var(--app-text);">My Projects</h1>
            <a asp-page="./Create" class="btn btn-proust">Upload +</a>
        </div>

        @if (!Model.Jobs.Any())
        {
            <div class="card" style="text-align: center; padding: 100px 20px; border-radius: 4px;">
                <div style="margin-bottom: 24px; opacity: 0.2;">
                    <svg style="width: 80px; height: 80px;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path><polyline points="17 8 12 3 7 8"></polyline><line x1="12" y1="3" x2="12" y2="15"></line></svg>
                </div>
                <h2 style="font-size: 1.5rem; font-weight: 700; margin-bottom: 8px;">No projects yet</h2>
                <p style="color: #666; margin-bottom: 32px;">Start your first transcription by uploading an audio or video file.</p>
                <a asp-page="./Create" class="btn" style="background: var(--app-header); color: #fff; border-radius: 4px; padding: 12px 32px;">Create Project</a>
            </div>
        }
        else
        {
            <div class="card" style="padding: 0; overflow: hidden; border-radius: 4px; border: 1px solid var(--border-color);">
                <table class="data-table" style="width: 100%; border-collapse: collapse;">
                    <thead>
                        <tr style="text-align: left; background: #fff; border-bottom: 1px solid var(--border-color); font-size: 0.75rem; text-transform: uppercase; color: #666; letter-spacing: 0.05em;">
                            <th style="padding: 16px 24px;">Filename</th>
                            <th style="padding: 16px 24px;">Status</th>
                            <th style="padding: 16px 24px;">Created</th>
                            <th style="padding: 16px 24px;">Duration</th>
                            <th style="padding: 16px 24px;">Confidence</th>
                            <th style="padding: 16px 24px; text-align: right;">Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var job in Model.Jobs)
                        {
                            <tr style="background: #fff; border-bottom: 1px solid #f3f4f6; transition: background 0.2s ease;">
                                <td style="padding: 20px 24px;">
                                    <div style="font-weight: 700; color: #111; font-size: 0.95rem;">@job.OriginalFilename</div>
                                    <div style="font-size: 0.75rem; color: #888; text-transform: uppercase;">@job.Mode</div>
                                </td>
                                <td style="padding: 20px 24px;">
                                    @{
                                        var statusClass = job.Status.ToLower() == "completed" ? "badge-completed" : "badge-processing";
                                    }
                                    <span class="badge-status @statusClass">
                                        @if (job.Status != "Completed")
                                        {
                                            <svg style="width: 10px; height: 10px; animation: spin 2s linear infinite;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><path d="M21 12a9 9 0 11-6.219-8.56"></path></svg>
                                        }
                                        @job.Status.ToUpper()
                                    </span>
                                </td>
                                <td style="padding: 20px 24px; font-size: 0.85rem; color: #666;">
                                    @job.CreatedAt.ToLocalTime().ToString("MMM dd, yyyy HH:mm")
                                </td>
                                <td style="padding: 20px 24px; font-size: 0.85rem; color: #666; font-family: monospace;">
                                    @(TimeSpan.FromSeconds(job.DurationSeconds).ToString(@"mm\:ss"))
                                </td>
                                <td style="padding: 20px 24px;">
                                    @if (job.Status == "Completed")
                                    {
                                        <div style="width: 100px; height: 6px; background: #eee; border-radius: 30px; overflow: hidden;">
                                            <div style="width: @(job.OverallConfidence * 100)%; height: 100%; background: #10b981;"></div>
                                        </div>
                                    }
                                    else
                                    {
                                        <span style="color: #ccc;">--</span>
                                    }
                                </td>
                                <td style="padding: 20px 24px; text-align: right;">
                                    <div style="display: flex; gap: 8px; justify-content: flex-end;">
                                        <a asp-page="./Details" asp-route-id="@job.Id" class="btn" style="padding: 6px 12px; font-size: 0.75rem; background: #fff; border: 1px solid #ddd; border-radius: 4px; color: #333;">Open</a>
                                        <form method="post" asp-page-handler="Delete" asp-route-id="@job.Id" onsubmit="return confirm('Delete this project?')">
                                            <button type="submit" class="btn" style="padding: 6px 12px; font-size: 0.75rem; background: #fff; border: 1px solid #fee2e2; border-radius: 4px; color: #ef4444;">Delete</button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

<style>
    @@keyframes spin { from { transform: rotate(0deg); } to { transform: rotate(360deg); } }
    tr:hover { background: #fafafa !important; }
</style>
