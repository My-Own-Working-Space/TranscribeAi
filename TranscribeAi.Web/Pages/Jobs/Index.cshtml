@page
@model TranscribeAi.Web.Pages.Jobs.IndexModel
@{
    ViewData["Title"] = "Transcription History";
}

<div class="animate-in">
    <div class="card-header" style="margin-bottom: 24px;">
        <div>
            <h1 class="card-title" style="font-size: 2rem;">📋 Transcription History</h1>
            <p style="color: var(--text-secondary); margin-top: 4px;">Manage and view your previous transcription requests.</p>
        </div>
        <a asp-page="./Create" class="btn btn-primary btn-lg">➕ New Transcription</a>
    </div>

    @if (!Model.Jobs.Any())
    {
        <div class="card" style="text-align: center; padding: 60px 20px;">
            <div style="font-size: 4rem; margin-bottom: 24px;">📝</div>
            <h2 class="card-title">No transcriptions yet</h2>
            <p style="color: var(--text-secondary); margin-bottom: 32px; max-width: 400px; margin-left: auto; margin-right: auto;">
                Start transcribing your audio and video files to see them here. Our AI will handle everything for you.
            </p>
            <a asp-page="./Create" class="btn btn-primary">Start Your First Job</a>
        </div>
    }
    else
    {
        <div class="card">
            <div class="table-container">
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>File Name</th>
                            <th>Status</th>
                            <th>Created</th>
                            <th>Duration</th>
                            <th>Confidence</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var job in Model.Jobs)
                        {
                            <tr>
                                <td>
                                    <div style="font-weight: 500; color: var(--text-primary); max-width: 300px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">
                                        @job.OriginalFilename
                                    </div>
                                    <div style="font-size: 0.75rem; color: var(--text-muted);">
                                        Mode: @job.Mode
                                    </div>
                                </td>
                                <td>
                                    @{
                                        var badgeClass = $"badge-{job.Status.ToLower()}";
                                    }
                                    <span class="badge @badgeClass">
                                        @if (job.Status == "Processing")
                                        {
                                            <span class="pulse">●</span>
                                        }
                                        @job.Status
                                    </span>
                                </td>
                                <td>
                                    <div style="font-size: 0.85rem;">@job.CreatedAt.ToLocalTime().ToString("MMM dd, yyyy")</div>
                                    <div style="font-size: 0.75rem; color: var(--text-muted);">@job.CreatedAt.ToLocalTime().ToString("HH:mm")</div>
                                </td>
                                <td style="font-family: 'JetBrains Mono', monospace; font-size: 0.85rem;">
                                    @{
                                        var ts = TimeSpan.FromSeconds(job.DurationSeconds);
                                        var dur = ts.TotalHours >= 1 ? ts.ToString(@"hh\:mm\:ss") : ts.ToString(@"mm\:ss");
                                    }
                                    @dur
                                </td>
                                <td>
                                    @if (job.Status == "Completed")
                                    {
                                        <div style="display: flex; align-items: center; gap: 8px;">
                                            <div style="width: 40px; height: 4px; background: rgba(255,255,255,0.05); border-radius: 2px;">
                                                <div style="width: @(job.OverallConfidence * 100)%; height: 100%; background: var(--success); border-radius: 2px;"></div>
                                            </div>
                                            <span style="font-size: 0.8rem; color: var(--text-secondary);">@job.OverallConfidence.ToString("P0")</span>
                                        </div>
                                    }
                                    else
                                    {
                                        <span style="color: var(--text-muted);">--</span>
                                    }
                                </td>
                                <td>
                                    <div style="display: flex; gap: 8px;">
                                        <a asp-page="./Details" asp-route-id="@job.Id" class="btn btn-secondary btn-sm">View Details</a>
                                        <form method="post" asp-page-handler="Delete" asp-route-id="@job.Id" onsubmit="return confirm('Are you sure you want to delete this job?')">
                                            <button type="submit" class="btn btn-secondary btn-sm" style="color: var(--danger);">🗑️</button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>
