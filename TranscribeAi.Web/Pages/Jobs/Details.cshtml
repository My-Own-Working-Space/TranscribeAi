@page "{id:guid}"
@model TranscribeAi.Web.Pages.Jobs.DetailsModel
@{
    ViewData["Title"] = Model.Job.OriginalFilename;
    var isProcessing = Model.Job.Status == JobStatus.Queued || Model.Job.Status == JobStatus.Processing;
}

<div class="animate-in">
    <!-- Header -->
    <div class="card-header" style="margin-bottom: 24px; align-items: flex-start;">
        <div style="flex: 1;">
            <div style="display: flex; align-items: center; gap: 12px; margin-bottom: 8px;">
                <a asp-page="./Index" class="btn btn-secondary btn-sm">⬅ Back</a>
                <h1 class="card-title" style="font-size: 1.5rem;">@Model.Job.OriginalFilename</h1>
                <span id="jobStatusBadge" class="badge badge-@(Model.Job.Status.ToString().ToLower())">
                    @if (isProcessing) { <span class="pulse">●</span> }
                    @Model.Job.Status
                </span>
            </div>
            <div style="font-size: 0.85rem; color: var(--text-muted); display: flex; gap: 16px;">
                <span>📅 Created: @Model.Job.CreatedAt.ToLocalTime().ToString("MMM dd, HH:mm")</span>
                <span>⏱ Duration: @(TimeSpan.FromSeconds(Model.Job.DurationSeconds).ToString(@"mm\:ss"))</span>
                <span>⚖ Confidence: @(Model.Job.OverallConfidence.ToString("P1"))</span>
            </div>
        </div>

        <div style="display: flex; gap: 12px;">
            <div class="btn-group">
                <a asp-page-handler="Export" asp-route-id="@Model.Job.Id" asp-route-format="txt" class="btn btn-secondary btn-sm">📄 TXT</a>
                <a asp-page-handler="Export" asp-route-id="@Model.Job.Id" asp-route-format="srt" class="btn btn-secondary btn-sm">🎬 SRT</a>
                <a asp-page-handler="Export" asp-route-id="@Model.Job.Id" asp-route-format="docx" class="btn btn-secondary btn-sm">📝 DOCX</a>
            </div>
        </div>
    </div>

    <!-- Processing Overlay (SignalR) -->
    <div id="processingStates" style="@(isProcessing ? "" : "display: none;") margin-bottom: 32px;">
        <div class="card card-glass" style="border-color: var(--accent-primary); border-style: dashed;">
            <div style="display: flex; gap: 20px; align-items: center;">
                <div style="font-size: 2.5rem;">⚙️</div>
                <div style="flex: 1;">
                    <h3 id="progressStep" style="margin-bottom: 4px;">Transcribing audio...</h3>
                    <p id="progressDetail" style="color: var(--text-secondary); font-size: 0.85rem; margin-bottom: 12px;">Our AI is analyzing the sound waves. This usually takes 1/3 of the audio duration.</p>
                    <div class="progress-bar-track">
                        <div id="progressBar" class="progress-bar-fill" style="width: 5%;"></div>
                    </div>
                </div>
                <div id="progressPercent" style="font-size: 1.5rem; font-weight: 700; color: var(--accent-primary);">5%</div>
            </div>
        </div>
    </div>

    <div style="display: grid; grid-template-columns: 1fr 380px; gap: 24px; align-items: start;">
        <!-- Column 1: Transcript -->
        <div style="display: flex; flex-direction: column; gap: 24px;">
            <div class="card">
                <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px;">
                    <h2 class="card-title" style="font-size: 1.1rem;">📝 Transcript</h2>
                    <input type="text" id="transcriptSearch" class="form-input" placeholder="Search transcript..." style="width: 250px; padding: 6px 12px; font-size: 0.85rem;" />
                </div>

                <div id="transcriptView" style="max-height: 70vh; overflow-y: auto; padding-right: 12px;">
                    @if (Model.Segments.Any())
                    {
                        <ul class="segment-list">
                            @foreach (var seg in Model.Segments)
                            {
                                <li class="segment-item" data-text="@seg.Text.ToLower()">
                                    <span class="segment-time">@TimeSpan.FromSeconds(seg.Start).ToString(@"mm\:ss")</span>
                                    <p class="segment-text">@seg.Text</p>
                                </li>
                            }
                        </ul>
                    }
                    else if (!string.IsNullOrEmpty(Model.Job.Transcript))
                    {
                        <p style="white-space: pre-wrap; line-height: 1.8;">@Model.Job.Transcript</p>
                    }
                    else if (!isProcessing)
                    {
                        <p style="color: var(--text-muted); font-style: italic;">No transcript content available.</p>
                    }
                </div>
            </div>

            <!-- Action Items -->
            @if (Model.Actions.Any())
            {
                <div class="card">
                    <h2 class="card-title" style="margin-bottom: 20px; font-size: 1.1rem;">✅ Action Items</h2>
                    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 16px;">
                        @foreach (var action in Model.Actions)
                        {
                            <div class="card" style="padding: 16px; background: rgba(255,255,255,0.02);">
                                <div style="display: flex; gap: 12px;">
                                    <input type="checkbox" @(action.IsCompleted ? "checked" : "") style="width: 20px; height: 20px;" disabled />
                                    <div style="flex: 1;">
                                        <p style="font-size: 0.9rem; font-weight: 500; margin-bottom: 4px;">@action.TaskDescription</p>
                                        <div style="display: flex; gap: 12px; font-size: 0.75rem; color: var(--text-muted);">
                                            <span>👤 @action.Assignee</span>
                                            <span>📅 @action.Deadline</span>
                                        </div>
                                    </div>
                                    <span class="badge" style="background: rgba(255,255,255,0.1); height: fit-content;">@action.Priority</span>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            }
        </div>

        <!-- Column 2: AI Intelligence -->
        <div style="display: flex; flex-direction: column; gap: 24px; position: sticky; top: 88px;">
            <!-- AI Summary -->
            @if (Model.Summary != null)
            {
                <div class="card card-glass">
                    <h2 class="card-title" style="margin-bottom: 16px; font-size: 1.1rem;">✨ AI Summary</h2>
                    <div style="font-size: 0.9rem; line-height: 1.6; color: var(--text-primary);">
                        @Html.Raw(Model.Summary.Summary.Replace("\n", "<br/>"))
                    </div>
                    
                    <h3 style="font-size: 0.85rem; text-transform: uppercase; letter-spacing: 0.05em; color: var(--text-muted); margin: 20px 0 12px;">Key Insights</h3>
                    <ul style="list-style: none; display: flex; flex-direction: column; gap: 10px;">
                        @foreach (var pt in Model.Summary.KeyPoints)
                        {
                            <li style="font-size: 0.85rem; display: flex; gap: 10px;">
                                <span style="color: var(--accent-primary);">✦</span>
                                <span>@pt</span>
                            </li>
                        }
                    </ul>

                    @if (!string.IsNullOrEmpty(Model.Summary.Conclusion))
                    {
                        <div style="margin-top: 20px; padding-top: 16px; border-top: 1px solid var(--border-color); font-size: 0.85rem; font-style: italic;">
                            <strong>Takeaway:</strong> @Model.Summary.Conclusion
                        </div>
                    }
                </div>
            }

            <!-- AI Chat -->
            <div class="card card-glass" id="chatCard">
                <h2 class="card-title" style="margin-bottom: 16px; font-size: 1.1rem;">💬 Ask the AI</h2>
                <div id="chatMessages" style="max-height: 300px; overflow-y: auto; display: flex; flex-direction: column; gap: 12px; margin-bottom: 16px; padding-right: 8px;">
                    @foreach (var msg in Model.ChatHistory)
                    {
                        <div class="chat-msg chat-msg-@msg.Role.ToLower()" style="padding: 10px 14px; border-radius: var(--radius-md); font-size: 0.85rem; align-self: @(msg.Role.ToLower() == "user" ? "flex-end" : "flex-start"); background: @(msg.Role.ToLower() == "user" ? "var(--accent-primary)" : "rgba(255,255,255,0.05)"); color: @(msg.Role.ToLower() == "user" ? "white" : "var(--text-primary)"); max-width: 90%;">
                            @msg.Content
                        </div>
                    }
                    @if (!Model.ChatHistory.Any())
                    {
                        <p id="chatPlaceholder" style="color: var(--text-muted); font-size: 0.8rem; text-align: center;">Ask a question about this transcript.</p>
                    }
                </div>

                <div style="display: flex; gap: 8px;">
                    <textarea id="chatInput" class="form-input" placeholder="Type your question..." rows="1" style="resize: none; font-size: 0.85rem;"></textarea>
                    <button id="sendChatBtn" class="btn btn-primary" style="padding: 8px 12px;">🚀</button>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const jobId = "@Model.Job.Id";
        const initialStatus = "@Model.Job.Status";
    </script>
    <script src="~/js/signalr-progress.js" asp-append-version="true"></script>
    <script>
        // ── Transcript Search ──
        document.getElementById('transcriptSearch').addEventListener('input', (e) => {
            const query = e.target.value.toLowerCase();
            document.querySelectorAll('.segment-item').forEach(item => {
                const text = item.getAttribute('data-text');
                item.style.display = text.includes(query) ? 'flex' : 'none';
            });
        });

        // ── AI Chat ──
        const chatInput = document.getElementById('chatInput');
        const sendBtn = document.getElementById('sendChatBtn');
        const chatMsgs = document.getElementById('chatMessages');
        const chatPlaceholder = document.getElementById('chatPlaceholder');

        async function sendChat() {
            const question = chatInput.value.trim();
            if (!question) return;

            chatInput.value = '';
            if (chatPlaceholder) chatPlaceholder.remove();

            // Append user message
            const userMsg = document.createElement('div');
            userMsg.className = 'chat-msg chat-msg-user';
            userMsg.style = "padding: 10px 14px; border-radius: var(--radius-md); font-size: 0.85rem; align-self: flex-end; background: var(--accent-primary); color: white; max-width: 90%; margin-bottom: 12px;";
            userMsg.textContent = question;
            chatMsgs.appendChild(userMsg);
            chatMsgs.scrollTop = chatMsgs.scrollHeight;

            // Loading state
            const loadingMsg = document.createElement('div');
            loadingMsg.className = 'chat-msg chat-msg-assistant pulse';
            loadingMsg.style = "padding: 10px 14px; border-radius: var(--radius-md); font-size: 0.85rem; align-self: flex-start; background: rgba(255,255,255,0.05); color: var(--text-primary); max-width: 90%; margin-bottom: 12px;";
            loadingMsg.textContent = "AI is thinking...";
            chatMsgs.appendChild(loadingMsg);

            try {
                const formData = new FormData();
                formData.append('question', question);
                
                const response = await fetch(`?handler=Chat&id=${jobId}`, {
                    method: 'POST',
                    headers: { 'X-CSRF-TOKEN': document.querySelector('input[name="__RequestVerificationToken"]').value },
                    body: formData
                });

                const data = await response.json();
                loadingMsg.classList.remove('pulse');
                loadingMsg.textContent = data.answer;

                // TODO: Show sources below the answer
            } catch (error) {
                loadingMsg.textContent = "Sorry, something went wrong.";
                loadingMsg.style.color = "var(--danger)";
            }
            
            chatMsgs.scrollTop = chatMsgs.scrollHeight;
        }

        sendBtn.addEventListener('click', sendChat);
        chatInput.addEventListener('keypress', (e) => { if (e.key === 'Enter') sendChat(); });

        // Anti-forgery for fetch
        @Html.AntiForgeryToken()
    </script>
}
