@page "{id}"
@model TranscribeAi.Web.Pages.Jobs.DetailsModel
@{
    ViewData["Title"] = Model.Job.OriginalFilename;
}

<div class="details-page">
    <div class="container">
        <!-- ═══ Header ═══ -->
        <div class="details-header">
            <div style="display: flex; justify-content: space-between; align-items: flex-end; width: 100%;">
                <div>
                    <a asp-page="/Jobs/Index" style="text-decoration: none; font-size: 0.85rem; font-weight: 700; color: var(--accent-primary); text-transform: uppercase; margin-bottom: 12px; display: block;">← Back to Projects</a>
                    <div style="display: flex; align-items: center; gap: 16px;">
                        <h1 style="font-size: 2rem; font-weight: 800; color: var(--text-primary); margin: 0;">@Model.Job.ProjectName</h1>
                        <span id="jobStatusBadge" class="badge badge-@Model.Job.Status.ToString().ToLower()" style="font-size: 0.85rem; padding: 6px 12px; border-radius: 20px;">@Model.Job.Status</span>
                    </div>
                    @if (!string.IsNullOrEmpty(Model.Job.Description))
                    {
                        <p style="color: var(--text-muted); margin-top: 8px; font-size: 0.95rem;">@Model.Job.Description</p>
                    }
                </div>
                <div style="display: flex; gap: 12px;">
                    <div class="dropdown">
                        <button class="btn" style="border: 1px solid var(--border-color); background: white;">Export</button>
                    </div>
                </div>
            </div>
        </div>

        <div class="details-grid">
            <!-- ═══ Main Content Column ═══ -->
            <div class="transcript-area" id="transcriptArea">
                <!-- ═══ Media Header (Sticky) ═══ -->
                <div class="media-header">
                    @{
                        var ext = System.IO.Path.GetExtension(Model.Job.StoragePath ?? "").ToLower();
                        var isVideo = ext == ".mp4" || ext == ".mkv" || ext == ".webm";
                    }
                    @if (isVideo)
                    {
                        <video id="mediaPlayer" controls style="width: 100%; border-radius: 8px; background: #000; box-shadow: 0 4px 20px rgba(0,0,0,0.15);">
                            <source src="@Url.Page("./Details", "File", new { id = Model.Job.Id })" type="video/mp4">
                        </video>
                    }
                    else
                    {
                        <div style="background: var(--bg-secondary); padding: 16px; border-radius: 8px; border: 1px solid var(--border-color);">
                            <audio id="mediaPlayer" controls style="width: 100%;">
                                <source src="@Url.Page("./Details", "File", new { id = Model.Job.Id })" type="audio/mpeg">
                            </audio>
                        </div>
                    }
                </div>
                @if (!Model.Segments.Any() && string.IsNullOrEmpty(Model.Job.Transcript))
                {
                    <div style="padding: 100px 0; text-align: center;">
                        <h3 style="color: var(--text-muted);">Transcription in progress...</h3>
                        <p style="color: var(--text-muted); font-size: 0.9rem;">The transcript will appear here automatically when ready.</p>
                    </div>
                }
                else
                {
                    @foreach (var segment in Model.Segments)
                    {
                        <div class="segment">
                            <div class="speaker-col">
                                <div class="speaker-tag">Speaker</div>
                                <div class="timestamp" data-start="@segment.Start" style="cursor: pointer; color: var(--accent-primary); font-weight: 700;">
                                    @TimeSpan.FromSeconds(segment.Start).ToString(@"mm\:ss")
                                </div>
                            </div>
                            <div class="text-col">
                                @segment.Text
                            </div>
                        </div>
                    }
                }
            </div>

            <!-- ═══ AI Side Panel ═══ -->
            <aside class="ai-side">
                <div class="ai-panel">
                    <div class="ai-section-title">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"></path></svg>
                        AI Summary
                    </div>
                    
                    @if (Model.Job.Summary != null)
                    {
                        <div class="ai-content summary-content">
                            @Model.Job.Summary.Summary
                        </div>
                        
                        <div style="margin-top: 32px;" class="insight-card">
                            <div class="ai-section-title">Key Insights</div>
                            <ul class="key-point-list">
                                @if (!string.IsNullOrEmpty(Model.Job.Summary.KeyPoints))
                                {
                                    /* In a real app we'd deserialize JSON, but for this demo let's treat as text lines */
                                    @foreach (var point in Model.Job.Summary.KeyPoints.Replace("[", "").Replace("]", "").Replace("\"", "").Split(','))
                                    {
                                        <li class="key-point-item">@point.Trim()</li>
                                    }
                                }
                            </ul>
                        </div>

                        <div style="margin-top: 32px;">
                            <div class="ai-section-title">Action Items</div>
                            @if (Model.Actions != null && Model.Actions.Any())
                            {
                                @foreach (var action in Model.Actions)
                                {
                                    <div class="action-item-card" style="padding: 12px; background: rgba(255,255,255,0.03); border-radius: 4px; margin-bottom: 8px; border: 1px solid var(--border-color);">
                                        <div style="font-weight: 700; font-size: 0.9rem;">@action.Assignee</div>
                                        <div style="font-size: 0.85rem; color: var(--text-primary); margin: 6px 0;">@action.TaskDescription</div>
                                        <div style="font-size: 0.75rem; color: var(--text-muted);">Priority: @action.Priority | Deadline: @action.Deadline</div>
                                    </div>
                                }
                            }
                            else
                            {
                                <div style="color: var(--text-muted); font-style: italic; font-size: 0.85rem;">
                                    No action items extracted.
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="ai-content" style="color: var(--text-muted); font-style: italic;">
                            AI intelligence is analyzing this transcription. Results will appear shortly.
                        </div>
                    }
                </div>
            </aside>
        </div>
    </div>
</div>

<style>
    @@keyframes spin { from { transform: rotate(0deg); } to { transform: rotate(360deg); } }
    .app-main { padding: 0 !important; max-width: 100% !important; margin: 0 !important; }
    
    .segment { 
        padding: 16px; 
        border-radius: 8px; 
        transition: all 0.3s ease;
        border-left: 4px solid transparent;
    }
    
    .segment:hover { 
        background: rgba(var(--accent-primary-rgb), 0.03); 
    }
    
    .active-segment {
        background: rgba(var(--accent-primary-rgb), 0.08) !important;
        border-left-color: var(--accent-primary);
    }
    
    .timestamp:hover {
        text-decoration: underline;
    }
</style>

@section Scripts {
    <script>
        const jobId = "@Model.Job.Id";
        const initialStatus = "@Model.Job.Status";
    </script>
    <script src="~/js/signalr-progress.js" asp-append-version="true"></script>
}
