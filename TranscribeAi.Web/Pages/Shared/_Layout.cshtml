@{
    var isHomePage = ViewContext.RouteData.Values["page"]?.ToString() == "/Index" && !(User.Identity?.IsAuthenticated ?? false);
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — TranscribeAI</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet" />
    <link rel="icon" type="image/png" href="~/images/logo.png" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <!-- ═══ Navigation (High Contrast Solid) ═══ -->
    <nav class="navbar">
        <div class="nav-container">
            <a class="nav-brand" href="/">
                <img src="/images/logo.png" alt="Logo" style="height: 28px; margin-right: 8px; vertical-align: middle; filter: brightness(0) invert(1);" />
                <span class="brand-text">transcribeai.</span>
            </a>

            <div class="nav-links">
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <a href="/Jobs" class="nav-link">My Projects</a>
                    @if (User.IsInRole("Admin"))
                    {
                        <a href="/Admin/Dashboard" class="nav-link">Admin</a>
                    }
                    <div style="display: flex; align-items: center; gap: 16px;">
                        @{
                            var fullName = User.FindFirst("FullName")?.Value;
                            var displayName = !string.IsNullOrEmpty(fullName) ? fullName : User.Identity.Name;
                        }
                        <span style="color: rgba(255,255,255,0.7); font-size: 0.85rem; font-weight: 500;">@displayName</span>
                        <form method="post" asp-page="/Account/Logout" class="nav-logout-form" style="display:inline;">
                            <button type="submit" class="nav-link" style="background:none; border: 1px solid rgba(255,255,255,0.3); border-radius: 4px; padding: 4px 10px; cursor:pointer;">Logout</button>
                        </form>
                        <a href="/Jobs/Create" class="btn btn-white">+ New</a>
                    </div>
                }
                else
                {
                    <a href="/Account/Login" class="nav-link">Login</a>
                    <a href="/Account/Register" class="btn btn-white">Get Started</a>
                }
            </div>
        </div>
    </nav>

    <!-- ═══ Main Content ═══ -->
    <main>
        @RenderBody()
    </main>

    <footer style="padding: 60px 24px; border-top: 1px solid #eee; background: #fff; text-align: center; color: #999; font-size: 0.85rem;">
        <div class="container">
            <p>&copy; @DateTime.UtcNow.Year transcribeai. — Professional Audio Intelligence</p>
        </div>
    </footer>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.7/signalr.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
