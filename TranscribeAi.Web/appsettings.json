{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    }
  },
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=transcribe.db"
  },
  "TranscribeAi": {
    "AppName": "TranscribeAI",
    "AppVersion": "3.0.0",
    "MaxFileSizeMb": 200,
    "SupportedFormats": ["wav", "mp3", "flac", "ogg", "m4a", "mp4", "mkv", "webm"],
    "TempUploadDir": "temp_uploads"
  },
  "Groq": {
    "ApiKey": "",
    "Model": "llama-3.3-70b-versatile"
  },
  "AllowedHosts": "*"
}
