# TranscribeAI Environment Configuration
# Copy this file to .env and update values

# =============================================================================
# Application Settings
# =============================================================================
APP_NAME=TranscribeAI
DEBUG=false
LOG_LEVEL=INFO

# =============================================================================
# Server Configuration
# =============================================================================
HOST=0.0.0.0
PORT=8000
RELOAD=true

# =============================================================================
# Audio Processing
# =============================================================================
MAX_AUDIO_SIZE_MB=100
# Comma-separated list of supported formats
SUPPORTED_FORMATS=wav,mp3,flac,ogg,m4a

# =============================================================================
# MCP Orchestrator
# =============================================================================
DEFAULT_TIMEOUT_SECONDS=300.0
MAX_CONCURRENT_AGENTS=3

# =============================================================================
# Storage Configuration
# =============================================================================
STORAGE_BACKEND=local
# Local storage path
LOCAL_STORAGE_PATH=./data

# S3 Configuration (if STORAGE_BACKEND=s3)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1
# S3_BUCKET_NAME=

# =============================================================================
# External API Keys (for transcribe_external tool)
# =============================================================================
# OpenAI Whisper API
# OPENAI_API_KEY=

# Google Cloud Speech-to-Text
# GOOGLE_APPLICATION_CREDENTIALS=

# AWS Transcribe
# AWS_TRANSCRIBE_REGION=

# Azure Speech Services
# AZURE_SPEECH_KEY=
# AZURE_SPEECH_REGION=
